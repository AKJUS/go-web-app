            "value": "Use in:"
        },
        {
            "action": "add",
            "key": "designedForItemTwoA",
            "namespace": "surgeCatalogueWashSludge",
            "value": "Urban humanitarian aid settings with a very high population density and imminent lack of space and transport capacityRefugee/IDP camps with a very high population densityScenarios with collapsed FS or wastewater (WW) management services (emptying & transport, treatment and disposal)"
        },
        {
            "action": "add",
            "key": "designedForItemTwoB",
            "namespace": "surgeCatalogueWashSludge",
            "value": "Scenarios where the traditional sanitation response is not sufficient (latrine pits fill up quicker than new construction is possible, no new construction of pits is possible)"
        },
        {
            "action": "add",
            "key": "emergencyServices",
            "namespace": "surgeCatalogueWashSludge",
            "value": "Emergency Services"
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionOneA",
            "namespace": "surgeCatalogueWashSludge",
            "value": "Estimated collection capacity of 20 m³/d FS roughly equivalent to 20 000 people. Can be scaled up or down as needed."
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionOneB",
            "namespace": "surgeCatalogueWashSludge",
            "value": "The included equipment allows for operation with different (logistical) access levels and ranges in case of"
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionOneC",
            "namespace": "surgeCatalogueWashSludge",
            "value": "Emptying from manual pumping to mobile vacuum pumps"
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionOneD",
            "namespace": "surgeCatalogueWashSludge",
            "value": "Transport from carrying to make-shift FS trucks"
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionTwoA",
            "namespace": "surgeCatalogueWashSludge",
            "value": "Estimated treatment capacity of 20 m³/d FS in a phased treatment approach. Can be scaled up or down as needed."
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionTwoB",
            "namespace": "surgeCatalogueWashSludge",
            "value": "All the needed equipment for the construction of the 1st and 2nd phase treatment plants are included in the FSM ERU treatment plant module. The first two phases were developed for disaster response/humanitarian aid missions, with an estimated duration of 2 years or more with regular operation and maintenance."
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionTwoC",
            "namespace": "surgeCatalogueWashSludge",
            "value": "1ˢᵗ phase – lime treatment"
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionTwoCC",
            "namespace": "surgeCatalogueWashSludge",
            "value": "The 1ˢᵗ phase of the treatment plant is set-up to quickly provide Lime treatment, a chemical treatment, increases the pH (makes it alkaline) in FS to such a degree that pathogenic bacteria die off. The limed FS is put on sludge drying beds which separate the solid and liquid parts. The solids are dried and incinerated, the liquids are filtered through the sludge drying beds and infiltrated into the ground. "
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionTwoD",
            "namespace": "surgeCatalogueWashSludge",
            "value": "2ⁿᵈ phase – aerobic treatment"
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionTwoDD",
            "namespace": "surgeCatalogueWashSludge",
            "value": "The 2ⁿᵈ phase of the treatment plant uses as main liquid-phase treatment process the activated sludge process which allows biological carbon and nitrogen removal. Before discharge into the environment the liquid effluent is sand filtered and disinfected with chlorine. The solids separated out of FS are dried and incinerated."
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionTwoE",
            "namespace": "surgeCatalogueWashSludge",
            "value": "3ʳᵈ phase – transferal to long-term sustainable treatment"
        },
        {
            "action": "add",
            "key": "emergencyServicesSectionTwoEE",
            "namespace": "surgeCatalogueWashSludge",
            "value": "The 3ʳᵈ phase of the treatment plant is different to the first two as it is not a one-way mobile, flat-packed, quick set-up plant, but a permanent construction adapted to local conditions. A guidebook for the technology decision of the permanent treatment plant was developed for use by WASH generalists during the design process with civil engineering companies."
        },
        {
            "action": "add",
            "key": "faecalSludgeManagement",
            "namespace": "surgeCatalogueWashSludge",
            "value": "Faecal Sludge Management (FSM, under development)"
        },
