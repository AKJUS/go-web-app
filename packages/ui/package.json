{
    "name": "@ifrc-go/ui",
    "description": "IFRC-GO UI Components Library",
    "version": "2.2.0",
    "type": "module",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/IFRCGo/go-web-app.git",
        "directory": "packages/ui"
    },
    "keywords": [
        "ifrc-go",
        "ui",
        "react",
        "component library"
    ],
    "scripts": {
        "typecheck": "tsc",
        "build": "vite build --emptyOutDir",
        "start": "vite build --watch",
        "lint:js": "eslint src",
        "lint:css": "stylelint \"./src/**/*.css\"",
        "lint": "pnpm lint:js && pnpm lint:css",
        "lint:fix": "pnpm lint:js --fix && pnpm lint:css --fix"
    },
    "files": [
        "dist/*"
    ],
    "main": "./dist/index.js",
    "exports": {
        "./index.css": {
            "import": "./dist/index.css"
        },
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./contexts": {
            "import": "./dist/contexts/index.js",
            "types": "./dist/contexts/index.d.ts"
        },
        "./hooks": {
            "import": "./dist/hooks/index.js",
            "types": "./dist/hooks/index.d.ts"
        },
        "./utils": {
            "import": "./dist/utils/index.js",
            "types": "./dist/utils/index.d.ts"
        },
        "./printable": {
            "import": "./dist/components/printable/index.js",
            "types": "./dist/components/printable/index.d.ts"
        }
    },
    "dependencies": {
        "@ifrc-go/icons": "^2.0.1",
        "@togglecorp/fujs": "^2.2.0",
        "jiti": "^2.6.1",
        "react-focus-on": "^3.10.2",
        "sanitize-html": "^2.17.2"
    },
    "peerDependencies": {
        "@ifrc-go/icons": "^1.3.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.4",
        "@eslint/json": "^1.0.0",
        "@types/node": "^20.19.37",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/sanitize-html": "^2.16.1",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "@vitejs/plugin-react-swc": "^4.0.0",
        "autoprefixer": "^10.4.27",
        "eslint": "^9.39.4",
        "eslint-config-airbnb": "19.0.4",
        "eslint-import-resolver-typescript": "^4.0.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-import-newlines": "^1.4.1",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.0",
        "eslint-plugin-react-refresh": "^0.4.26",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "glob": "^13.0.0",
        "postcss": "^8.5.8",
        "postcss-nested": "^7.0.2",
        "postcss-normalize": "^13.0.1",
        "postcss-preset-env": "^11.0.0",
        "react-focus-on": "^3.9.1",
        "sanitize-html": "^2.11.0",
        "stylelint": "^17.0.0",
        "stylelint-config-concentric": "^2.0.2",
        "stylelint-config-recommended": "^18.0.0",
        "stylelint-value-no-unknown-custom-properties": "^6.1.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.58.0",
        "vite": "^6.4.2",
        "vite-plugin-dts": "^4.0.0",
        "vite-plugin-lib-inject-css": "^2.0.0",
        "vite-tsconfig-paths": "^6.0.0",
        "vitest": "^4.0.0"
    }
}
