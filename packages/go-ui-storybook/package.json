{
    "name": "go-ui-storybook",
    "version": "1.0.11-beta.0",
    "private": true,
    "type": "module",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/IFRCGo/go-web-app.git",
        "directory": "packages/go-ui-storybook"
    },
    "scripts": {
        "build": "pnpm build-storybook",
        "lint:js": "eslint src",
        "lint": "pnpm lint:js",
        "lint:fix": "pnpm lint:js --fix",
        "preview": "vite preview --outDir storybook-static --port 6006",
        "storybook": "pnpm -F @ifrc-go/ui build && storybook dev -p 6006",
        "build-storybook": "pnpm -F @ifrc-go/ui build && storybook build",
        "chromatic": "dotenv -- cross-var chromatic --project-token=%CHROMATIC_PROJECT_TOKEN%"
    },
    "dependencies": {
        "@ifrc-go/icons": "^2.0.1",
        "@ifrc-go/ui": "workspace:^",
        "@storybook/addon-docs": "^8.6.18",
        "@storybook/preview-api": "^8.6.14",
        "@storybook/test": "^8.6.18",
        "@storybook/theming": "^8.6.14",
        "@togglecorp/fujs": "^2.2.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^1.9.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.4",
        "@storybook/addon-a11y": "^8.6.18",
        "@storybook/addon-designs": "^8.2.1",
        "@storybook/addon-essentials": "^8.6.14",
        "@storybook/addon-interactions": "^8.6.14",
        "@storybook/addon-links": "^8.6.18",
        "@storybook/addon-onboarding": "^8.6.18",
        "@storybook/blocks": "^8.6.14",
        "@storybook/react": "^8.6.18",
        "@storybook/react-vite": "^8.6.18",
        "@storybook/test": "^8.6.18",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "@vitejs/plugin-react-swc": "^4.0.0",
        "chromatic": "^16.0.0",
        "cross-var": "^1.1.0",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9.39.4",
        "eslint-config-airbnb": "19.0.4",
        "eslint-import-resolver-typescript": "^4.0.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-import-newlines": "^1.4.1",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.0",
        "eslint-plugin-react-refresh": "^0.4.26",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-storybook": "^0.10.2",
        "jiti": "^2.6.1",
        "storybook": "^8.6.18",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.58.0",
        "vite": "^6.4.2",
        "vite-tsconfig-paths": "^4.3.2"
    }
}
