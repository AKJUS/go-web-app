{
    "name": "go-web-app-workspace",
    "version": "1.0.0",
    "type": "module",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/IFRCGo/go-web-app.git"
    },
    "private": true,
    "scripts": {
        "postinstall": "patch-package",
        "lint:unused": "knip --tags=-knipignore",
        "build:ui": "pnpm workspace @ifrc-go/ui build",
        "build": "pnpm build:ui && pnpm workspace go-web-app build",
        "start:ui": "pnpm workspace @ifrc-go/ui start",
        "start:app": "pnpm build:ui && pnpm workspace go-web-app start",
        "generate:type": "pnpm workspace go-web-app generate:type",
        "preview": "pnpm workspace go-web-app preview",
        "storybook": "pnpm workspace go-ui-storybook storybook",
        "build-storybook": "pnpm workspace go-ui-storybook build-storybook",
        "chromatic": "pnpm workspace go-ui-storybook chromatic"
    },
    "devDependencies": {
        "knip": "^5.36.3",
        "patch-package": "^8.0.0"
    },
    "workspaces": [
        "app",
        "packages/ui",
        "packages/go-ui-storybook"
    ],
    "packageManager": "pnpm@8.6.0+sha1.71f9126a20cd3d00fa47c188f956918858180e54"
}
